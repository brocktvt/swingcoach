# Copy this to .env and fill in your values

# Generate a strong random key: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_IN_PRODUCTION

# Your Anthropic API key (from console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# Where to store uploaded swing videos
UPLOAD_DIR=./uploads

# Free tier: how many analyses per month before requiring Pro
FREE_ANALYSES_PER_MONTH=5

# Database (SQLite for local dev, switch to PostgreSQL for production)
DATABASE_URL=sqlite+aiosqlite:///./swingcoach.db
# DATABASE_URL=postgresql+asyncpg://user:password@localhost/swingcoach
